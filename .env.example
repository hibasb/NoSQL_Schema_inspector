# Clé API pour l'assistant IA (Chatbot) propulsé par Groq
# Obtenez votre clé ici : https://console.groq.com/keys
GROQ_API_KEY=votre_cle_api_groq_ici

# (Optionnel) Chemin vers votre fichier de credentials Firebase
# Si vous préférez l'utiliser au lieu de renseigner les champs manuellement dans l'interface
# GOOGLE_APPLICATION_CREDENTIALS=/chemin/vers/serviceAccountKey.json
